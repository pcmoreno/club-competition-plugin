{
  "name": "schaakclub-santpoort/club-competition-plugin",
  "description": "WordPress plugin for managing chess competition pairings, standings, and results for Schaakclub Santpoort",
  "type": "wordpress-plugin",
  "version": "1.0.0",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Paulo Moreno",
      "email": "pcmoreno@yahoo.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "symfony/dependency-injection": "^7.4",
    "symfony/validator": "^7.4",
    "symfony/security-core": "^7.4",
    "symfony/console": "^7.4",
    "symfony/security-csrf": "^7.4",
    "doctrine/dbal": "^3.7",
    "lcobucci/jwt": "^5.0",
    "dompdf/dompdf": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "mockery/mockery": "^1.5",
    "phpstan/phpstan": "^1.10",
    "friendsofphp/php-cs-fixer": "^3.40"
  },
  "config": {
    "platform": {
      "php": "8.2.31"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse",
    "lint": "php-cs-fixer fix --dry-run",
    "lint:fix": "php-cs-fixer fix"
  },
  "autoload": {
    "psr-4": {
      "SCS\\": "src/",
      "SCS\\includes\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SCS\\Tests\\": "tests/"
    }
  }
}
